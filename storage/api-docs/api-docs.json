                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/expert/application": {
            "post": {
                "tags": [
                    "Expert Application"
                ],
                "summary": "Submit an expert application",
                "operationId": "a1e6555478e90f2c7146171e29909a23",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "category_id",
                                    "subcategory_id",
                                    "professional_headline",
                                    "bio",
                                    "skill_ids"
                                ],
                                "properties": {
                                    "category_id": {
                                        "type": "integer"
                                    },
                                    "subcategory_id": {
                                        "type": "integer"
                                    },
                                    "professional_headline": {
                                        "type": "string",
                                        "maxLength": 255
                                    },
                                    "bio": {
                                        "type": "string",
                                        "maxLength": 10000
                                    },
                                    "education": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "institution"
                                            ],
                                            "properties": {
                                                "institution": {
                                                    "type": "string",
                                                    "maxLength": 255
                                                },
                                                "degree": {
                                                    "type": "string",
                                                    "nullable": true,
                                                    "maxLength": 255
                                                },
                                                "year": {
                                                    "type": "integer",
                                                    "nullable": true,
                                                    "maximum": 2100,
                                                    "minimum": 1900
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "nullable": true,
                                        "maxItems": 20
                                    },
                                    "experience": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "title"
                                            ],
                                            "properties": {
                                                "title": {
                                                    "type": "string",
                                                    "maxLength": 255
                                                },
                                                "organization": {
                                                    "type": "string",
                                                    "nullable": true,
                                                    "maxLength": 255
                                                },
                                                "start_year": {
                                                    "type": "integer",
                                                    "nullable": true,
                                                    "maximum": 2100,
                                                    "minimum": 1900
                                                },
                                                "end_year": {
                                                    "type": "integer",
                                                    "nullable": true,
                                                    "maximum": 2100,
                                                    "minimum": 1900
                                                },
                                                "description": {
                                                    "type": "string",
                                                    "nullable": true,
                                                    "maxLength": 2000
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "nullable": true,
                                        "maxItems": 30
                                    },
                                    "portfolio": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "url"
                                            ],
                                            "properties": {
                                                "title": {
                                                    "type": "string",
                                                    "nullable": true,
                                                    "maxLength": 255
                                                },
                                                "url": {
                                                    "type": "string",
                                                    "format": "uri",
                                                    "maxLength": 2048
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "nullable": true,
                                        "maxItems": 20
                                    },
                                    "skill_ids": {
                                        "type": "array",
                                        "items": {
                                            "type": "integer"
                                        },
                                        "maxItems": 50,
                                        "minItems": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Application submitted"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/expert/availability": {
            "get": {
                "tags": [
                    "Expert Availability"
                ],
                "summary": "Get the authenticated expert’s weekly availability",
                "operationId": "5982b5479752582670e596c4c3cdfa0b",
                "responses": {
                    "200": {
                        "description": "Availability retrieved"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Expert account required"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Expert Availability"
                ],
                "summary": "Replace the authenticated expert’s weekly availability",
                "operationId": "0e1e1d4db20f237645e58407057f5c4b",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "days"
                                ],
                                "properties": {
                                    "days": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "day_of_week",
                                                "enabled"
                                            ],
                                            "properties": {
                                                "day_of_week": {
                                                    "type": "integer",
                                                    "maximum": 6,
                                                    "minimum": 0
                                                },
                                                "enabled": {
                                                    "type": "boolean"
                                                },
                                                "slots": {
                                                    "type": "array",
                                                    "items": {
                                                        "required": [
                                                            "start",
                                                            "end"
                                                        ],
                                                        "properties": {
                                                            "start": {
                                                                "type": "string",
                                                                "format": "time",
                                                                "example": "09:00"
                                                            },
                                                            "end": {
                                                                "type": "string",
                                                                "format": "time",
                                                                "example": "10:00"
                                                            }
                                                        },
                                                        "type": "object"
                                                    },
                                                    "nullable": true,
                                                    "maxItems": 20
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "maxItems": 7,
                                        "minItems": 7
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Availability saved"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Expert account required"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
